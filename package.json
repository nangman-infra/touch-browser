{
  "name": "touch-browser",
  "private": true,
  "license": "BUSL-1.1",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "lint": "pnpm exec biome check .",
    "format": "pnpm exec biome format --write .",
    "contracts:check": "node scripts/validate-contract-layout.mjs",
    "contracts:manifest": "node scripts/generate-contract-manifest.mjs",
    "fixtures:snapshot": "node scripts/generate-fixture-snapshots.mjs",
    "fixtures:evidence": "node scripts/generate-fixture-evidence.mjs",
    "fixtures:session": "node scripts/generate-session-scenarios.mjs",
    "fixtures:memory": "node scripts/generate-memory-scenario.mjs",
    "fixtures:policy": "node scripts/generate-policy-scenarios.mjs",
    "fixtures:safety": "node scripts/generate-safety-metrics.mjs",
    "fixtures:metrics": "node scripts/generate-observation-metrics.mjs",
    "fixtures:browser-metrics": "node scripts/generate-browser-observation-metrics.mjs",
    "fixtures:live-metrics": "node scripts/generate-live-observation-metrics.mjs",
    "fixtures:citation-metrics": "node scripts/generate-citation-metrics.mjs",
    "fixtures:session-synthesis": "node scripts/generate-session-synthesis-scenario.mjs",
    "fixtures:action-surface": "node scripts/generate-action-surface-regression.mjs",
    "fixtures:latency-cost": "node scripts/generate-latency-cost-metrics.mjs",
    "fixtures:customer-fit": "node scripts/generate-customer-fit-economics.mjs",
    "fixtures:customer-proxy": "node scripts/generate-customer-proxy-tasks.mjs",
    "fixtures:ops-package": "node scripts/generate-ops-package-readiness.mjs",
    "fixtures:release-readiness": "node scripts/generate-release-readiness.mjs",
    "fixtures:public-web": "node scripts/generate-public-web-benchmark.mjs",
    "fixtures:doc-links": "node scripts/generate-doc-link-integrity.mjs",
    "fixtures:tool-comparison": "node scripts/generate-tool-comparison-benchmark.mjs",
    "fixtures:real-user-research": "node scripts/run-real-user-research-benchmark.mjs",
    "fixtures:reference-workflow": "node scripts/run-reference-research-workflow.mjs",
    "fixtures:staged-reference-workflow": "node scripts/run-staged-reference-workflow.mjs",
    "fixtures:public-reference-workflow": "node scripts/run-public-reference-workflow.mjs",
    "test:rust": "zsh -lic 'cargo test --workspace'",
    "typecheck": "pnpm exec tsc -p adapters/playwright/tsconfig.json --noEmit && pnpm exec tsc -p evals/tsconfig.json --noEmit",
    "test": "pnpm run contracts:check && pnpm run contracts:manifest && pnpm run fixtures:evidence && pnpm run fixtures:session && pnpm run fixtures:memory && pnpm run fixtures:policy && pnpm run fixtures:safety && pnpm run fixtures:metrics && pnpm run fixtures:browser-metrics && pnpm run fixtures:live-metrics && pnpm run fixtures:citation-metrics && pnpm run fixtures:session-synthesis && pnpm run fixtures:action-surface && pnpm run fixtures:latency-cost && pnpm run fixtures:doc-links && pnpm run fixtures:tool-comparison && pnpm run fixtures:reference-workflow && pnpm run fixtures:staged-reference-workflow && pnpm run fixtures:public-reference-workflow && pnpm run fixtures:real-user-research && pnpm run fixtures:customer-fit && pnpm run fixtures:customer-proxy && pnpm run fixtures:ops-package && pnpm run fixtures:release-readiness && pnpm run test:rust && pnpm exec vitest run --config adapters/playwright/vitest.config.ts && pnpm exec vitest run --config evals/vitest.config.ts",
    "adapter:playwright": "pnpm exec tsx adapters/playwright/src/index.ts",
    "evals:smoke": "pnpm exec tsx evals/src/index.ts",
    "mcp:bridge": "node scripts/touch-browser-mcp-bridge.mjs",
    "verifier:example": "node scripts/example-verifier.mjs",
    "bootstrap:local": "bash scripts/bootstrap-local.sh",
    "pilot:healthcheck": "node scripts/pilot-healthcheck.mjs",
    "pilot:reference-workflow": "node scripts/run-reference-research-workflow.mjs",
    "pilot:staged-reference-workflow": "node scripts/run-staged-reference-workflow.mjs",
    "pilot:public-reference-workflow": "node scripts/run-public-reference-workflow.mjs",
    "pilot:real-user-research": "node scripts/run-real-user-research-benchmark.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "ajv": "^8.17.1",
    "gpt-tokenizer": "^3.4.0",
    "json-schema-to-typescript": "^15.0.4",
    "playwright": "^1.54.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
