{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "target/**",
      "dist/**",
      "output/**",
      "sonar-reports/**",
      "adapters/playwright/dist-runtime/**",
      "contracts/generated/manifest.json",
      "contracts/generated/mcp-tool-catalog.json",
      "contracts/generated/mcp-tool-catalog.mjs",
      "fixtures/scenarios/**/*.json"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  }
}
