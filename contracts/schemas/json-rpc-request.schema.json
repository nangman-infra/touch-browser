{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "json-rpc-request.schema.json",
  "title": "JsonRpcRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["jsonrpc", "id", "method"],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer"
        }
      ]
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": ["object", "array", "null"]
    }
  }
}
