{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unsupported-claim.schema.json",
  "title": "UnsupportedClaim",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "claimId", "statement", "reason"],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "claimId": {
      "type": "string",
      "pattern": "^c[0-9]+$"
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "enum": [
        "no-supporting-block",
        "insufficient-support-score",
        "contradictory-evidence",
        "numeric-mismatch",
        "scope-mismatch",
        "status-mismatch",
        "negation-mismatch",
        "predicate-mismatch",
        "needs-more-browsing"
      ]
    },
    "checkedBlockRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^r[a-zA-Z0-9:_-]+$"
      },
      "uniqueItems": true
    },
    "guardFailures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "numeric-value",
              "numeric-unit",
              "scope",
              "status",
              "negation",
              "predicate",
              "anchor-coverage",
              "qualifier-coverage"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "nextActionHint": {
      "type": "string",
      "minLength": 1
    }
  }
}
