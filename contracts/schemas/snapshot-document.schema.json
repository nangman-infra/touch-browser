{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "snapshot-document.schema.json",
  "title": "SnapshotDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "stableRefVersion", "source", "budget", "blocks"],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "stableRefVersion": {
      "const": "1"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceUrl", "sourceType"],
      "properties": {
        "sourceUrl": {
          "type": "string",
          "minLength": 1
        },
        "sourceType": {
          "type": "string",
          "enum": ["fixture", "http", "playwright"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestedTokens",
        "estimatedTokens",
        "emittedTokens",
        "truncated"
      ],
      "properties": {
        "requestedTokens": {
          "type": "integer",
          "minimum": 1
        },
        "estimatedTokens": {
          "type": "integer",
          "minimum": 0
        },
        "emittedTokens": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "$ref": "snapshot-block.schema.json"
      },
      "minItems": 1
    }
  }
}
