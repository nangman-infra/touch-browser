        "title": {
          "const": "Search The Web"
        },
        "description": {
          "const": "Search the public docs/research web headlessly and structure the result page for follow-up browsing. Search engine selection is automatic; follow tb_search_open_top before read-view or extract."
        },
        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string"
              },
              "tabId": {
                "type": "string"
