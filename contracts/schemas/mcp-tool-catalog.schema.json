              "sessionId": {
                "type": "string"
              },
              "tabId": {
                "type": "string"
              }
            },
            "required": ["target"]
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "description", "inputSchema"],
      "properties": {
        "name": {
          "const": "tb_search"
