        "title": {
          "const": "Extract Evidence"
        },
        "description": {
          "const": "Extract evidence-supported and insufficient-evidence claims from the current target or daemon tab. Use this after tb_read_view confirms the tab scope on public docs or reference pages."
        },
        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "target": {
                "type": "string"
              },
              "claims": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "browser": {
                "type": "boolean"
              },
              "budget": {
                "type": "number"
              },
              "mainOnly": {
                "type": "boolean"
              },
              "verifierCommand": {
                "type": "string"
              },
              "sourceRisk": {
                "type": "string"
              },
              "sourceLabel": {
                "type": "string"
              },
              "allowDomains": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "sessionId": {
                "type": "string"
              },
              "tabId": {
                "type": "string"
              }
            },
            "required": ["claims"]
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "description", "inputSchema"],
