              "tabId": {
                "type": "string"
              },
              "rank": {
                "type": "number"
              }
            },
            "required": ["sessionId", "rank"]
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "description", "inputSchema"],
      "properties": {
        "name": {
          "const": "tb_search_open_top"
        },
        "title": {
          "const": "Open Top Search Results"
        },
        "description": {
          "const": "Open the top recommended search results into new research tabs. Prefer this immediately after tb_search, then inspect tabs with tb_read_view before tb_extract."
        },
        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string"
              },
              "tabId": {
                "type": "string"
              },
              "limit": {
                "type": "number"
              }
            },
            "required": ["sessionId"]
          }
        }
      }
    },
