        },
        "description": {
          "const": "Return a readable Markdown view of a target or daemon tab for scope checking on public docs and reference pages. Inspect mainContentQuality and mainContentReason before extracting claims."
        },
        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "target": {
                "type": "string"
              },
              "browser": {
                "type": "boolean"
              },
              "budget": {
                "type": "number"
              },
              "mainOnly": {
                "type": "boolean"
              },
              "sourceRisk": {
                "type": "string"
              },
              "sourceLabel": {
                "type": "string"
              },
              "allowDomains": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "sessionId": {
                "type": "string"
              },
              "tabId": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "description", "inputSchema"],
