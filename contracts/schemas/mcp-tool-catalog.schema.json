              "query": {
                "type": "string"
              },
              "budget": {
                "type": "number"
              }
            },
            "required": ["sessionId", "query"]
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "description", "inputSchema"],
      "properties": {
        "name": {
          "const": "tb_search_open_result"
        },
        "title": {
          "const": "Open One Search Result"
        },
        "description": {
          "const": "Open one structured search result into a new research tab when you must override the recommended order after tb_search."
        },
        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string"
