        "title": {
          "const": "Policy Report"
        },
        "description": {
          "const": "Return the policy evaluation for a target or daemon tab on the public docs/research web surface."
        },
        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "target": {
                "type": "string"
              },
              "browser": {
                "type": "boolean"
              },
              "sourceRisk": {
                "type": "string"
              },
              "sourceLabel": {
                "type": "string"
              },
              "allowDomains": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "sessionId": {
                "type": "string"
              },
              "tabId": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "description", "inputSchema"],
