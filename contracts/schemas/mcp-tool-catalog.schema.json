        "inputSchema": {
          "const": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "sourceRisk": {
                "type": "string"
              },
              "sourceLabel": {
                "type": "string"
              },
              "allowDomains": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["sessionId"]
