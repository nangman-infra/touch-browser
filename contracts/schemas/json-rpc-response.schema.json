{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "json-rpc-response.schema.json",
  "title": "JsonRpcResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["jsonrpc", "id"],
  "properties": {
    "jsonrpc": {
      "const": "2.0"
    },
    "id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "result": true,
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "data": true
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["result"],
      "properties": {
        "result": true,
        "error": false
      }
    },
    {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "integer"
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "data": true
          }
        },
        "result": false
      }
    }
  ]
}
